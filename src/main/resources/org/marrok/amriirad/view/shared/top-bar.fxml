<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<?import java.net.URL?>
<HBox alignment="CENTER" spacing="20" styleClass="top-bar" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.marrok.amriirad.controller.shared.TopBarController">
    
    <padding>
        <javafx.geometry.Insets bottom="10" left="20" right="20" top="10" />
    </padding>

    <!-- App Title & Back Button -->
    <HBox alignment="CENTER_LEFT" spacing="15" HBox.hgrow="ALWAYS">
        <Button fx:id="backBtn" onAction="#handleBack" styleClass="btn-outline" prefWidth="36" prefHeight="36">
            <tooltip><Tooltip text="الرجوع" /></tooltip>
            <graphic>
                <FontIcon iconLiteral="fas-arrow-right" iconSize="16" styleClass="icon-primary" />
            </graphic>
        </Button>
        <Label styleClass="text-heading" text="نظام أوامر الإيراد" />
    </HBox>

    <!-- Global Actions -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="8" fx:id="fiscalYearBox">
            <Label styleClass="text-small" text="السنة المالية:" />
            <ComboBox fx:id="fiscalYearCombo" prefWidth="120" promptText="اختر السنة" />
            <Button fx:id="addFiscalYearBtn" onAction="#handleAddFiscalYear" styleClass="btn-outline" prefWidth="32" prefHeight="32">
                <tooltip><Tooltip text="إضافة سنة مالية" /></tooltip>
                <graphic>
                    <FontIcon iconLiteral="fas-plus" iconSize="12" styleClass="icon-primary" />
                </graphic>
            </Button>
        </HBox>
        
        <Separator orientation="VERTICAL" prefHeight="25" />
        
        <Button fx:id="viewUsersBtn" onAction="#handleViewUsers" styleClass="btn-outline" prefWidth="36" prefHeight="36">
            <tooltip><Tooltip text="إدارة المستخدمين" /></tooltip>
            <graphic>
                <FontIcon iconLiteral="fas-user-shield" iconSize="18" styleClass="icon-primary" />
            </graphic>
        </Button>
        
        <Button fx:id="managePermissionsBtn" onAction="#handleManagePermissions" styleClass="btn-outline" prefWidth="36" prefHeight="36">
            <tooltip><Tooltip text="إدارة الصلاحيات" /></tooltip>
            <graphic>
                <FontIcon iconLiteral="fas-key" iconSize="18" styleClass="icon-primary" />
            </graphic>
        </Button>
        
        <Button fx:id="enterpriseSettingsBtn" onAction="#handleEnterpriseSettings" styleClass="btn-outline" prefWidth="36" prefHeight="36">
            <tooltip><Tooltip text="إعدادات المؤسسة" /></tooltip>
            <graphic>
                <FontIcon iconLiteral="fas-cog" iconSize="18" styleClass="icon-primary" />
            </graphic>
        </Button>

        <Button fx:id="viewAuditLogBtn" onAction="#handleViewAuditLog" styleClass="btn-outline" prefWidth="36" prefHeight="36">
            <tooltip><Tooltip text="سجل العمليات" /></tooltip>
            <graphic>
                <FontIcon iconLiteral="fas-history" iconSize="18" styleClass="icon-primary" />
            </graphic>
        </Button>
        
        <Separator orientation="VERTICAL" prefHeight="25" />
        
        <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="btn-danger-outline" prefWidth="36" prefHeight="36">
            <tooltip><Tooltip text="تسجيل الخروج" /></tooltip>
            <graphic>
                <FontIcon iconLiteral="fas-sign-out-alt" iconSize="18" styleClass="icon-danger" />
            </graphic>
        </Button>
    </HBox>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</HBox>
