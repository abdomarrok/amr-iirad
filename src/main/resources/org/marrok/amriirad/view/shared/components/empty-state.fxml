<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.marrok.amriirad.controller.shared.components.EmptyStateController"
      visible="false" managed="false" style="-fx-padding: 50;">

    <FontIcon fx:id="icon" iconLiteral="fas-folder-open" iconSize="64" styleClass="icon-muted" />
    
    <VBox alignment="CENTER" spacing="5.0">
        <Label fx:id="titleLabel" styleClass="text-heading, text-muted" text="لا توجد بيانات" />
        <Label fx:id="messageLabel" styleClass="text-body, text-muted" text="لم يتم العثور على أي نتائج تطابق بحثك." />
    </VBox>
    
    <Button fx:id="actionBtn" onAction="#onAction" styleClass="btn-outline" text="إضافة جديد" visible="false" managed="false" />

</VBox>
