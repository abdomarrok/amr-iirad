<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import java.net.URL?>
<VBox alignment="CENTER" spacing="20.0" prefWidth="400.0" style="-fx-padding: 30; -fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: -fx-theme-primary;" text="لغة الطباعة / Langue d'impression" />
                <Label style="-fx-text-fill: -fx-theme-text-muted;" text="اختر لغة طباعة الوثيقة / Choisir la langue" />
            </children>
        </VBox>
        
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="arabicBtn" prefHeight="100.0" prefWidth="150.0" styleClass="mode-card-secondary" text="العربية (AR)" contentDisplay="TOP">
                    <graphic>
                        <FontIcon iconLiteral="fas-language" iconSize="32" styleClass="icon-primary"/>
                    </graphic>
                </Button>
                <Button fx:id="frenchBtn" prefHeight="100.0" prefWidth="150.0" styleClass="mode-card-secondary" text="Français (FR)" contentDisplay="TOP">
                    <graphic>
                        <FontIcon iconLiteral="fas-globe" iconSize="32" styleClass="icon-primary"/>
                    </graphic>
                </Button>
            </children>
        </HBox>
        
        <Button fx:id="cancelBtn" mnemonicParsing="false" styleClass="btn-secondary" text="إلغاء / Annuler" prefWidth="100" />
    </children>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</VBox>
