<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox alignment="TOP_CENTER" spacing="0.0" styleClass="card" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <!-- Custom Header with Close Button -->
        <HBox alignment="CENTER_RIGHT" prefHeight="50.0" style="-fx-padding: 12 16 0 0;">
            <Button fx:id="closeIconBtn" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;">
                <graphic>
                    <FontIcon iconLiteral="fas-times" iconSize="20" styleClass="icon-secondary" />
                </graphic>
            </Button>
        </HBox>

        <VBox alignment="CENTER" spacing="32.0" style="-fx-padding: 0 48 48 48;">
            <children>
                <!-- Title Section -->
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label styleClass="text-heading" text="لغة الطباعة / Langue d'impression" />
                        <Label style="-fx-text-fill: -fx-theme-text-secondary;" styleClass="text-small" text="اختر لغة طباعة الوثيقة / Choisir la langue" />
                    </children>
                </VBox>
                
                <!-- Language Selection Cards -->
                <HBox alignment="CENTER" spacing="24.0">
                    <children>
                        <!-- Arabic Button -->
                        <Button fx:id="arabicBtn" contentDisplay="TOP" prefHeight="140.0" prefWidth="180.0" styleClass="language-card">
                            <graphic>
                                <VBox alignment="CENTER" spacing="12">
                                    <FontIcon iconLiteral="fas-language" iconSize="48" styleClass="icon-primary" />
                                    <Label styleClass="language-card-title" text="العربية" />
                                    <Label styleClass="language-card-subtitle" text="(AR)" />
                                </VBox>
                            </graphic>
                        </Button>

                        <!-- French Button -->
                        <Button fx:id="frenchBtn" contentDisplay="TOP" prefHeight="140.0" prefWidth="180.0" styleClass="language-card">
                            <graphic>
                                <VBox alignment="CENTER" spacing="12">
                                    <FontIcon iconLiteral="fas-globe-africa" iconSize="48" styleClass="icon-primary" />
                                    <Label styleClass="language-card-title" text="Français" />
                                    <Label styleClass="language-card-subtitle" text="(FR)" />
                                </VBox>
                            </graphic>
                        </Button>
                    </children>
                </HBox>
                
                <!-- Cancel Button -->
                <Button fx:id="cancelBtn" mnemonicParsing="false" style="-fx-padding: 12 24; -fx-font-size: 14; -fx-background-radius: 8;" text="إلغاء / Annuler" />
            </children>
        </VBox>
    </children>
    <stylesheets>
        <URL value="@../../css/master.css" />
        <URL value="@../../css/app.css" />
    </stylesheets>
</VBox>
