<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.VBox?>

<?import java.net.URL?>
<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-width: 1px; -fx-padding: 30;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ProgressBar fx:id="progressBar" prefWidth="250.0" progress="-1.0" />
        <Label fx:id="messageLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -fx-theme-primary;" text="جاري التحميل..." textAlignment="CENTER" wrapText="true" maxWidth="300" />
    </children>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</VBox>
