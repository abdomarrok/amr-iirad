<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700" prefWidth="1100" styleClass="main-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.marrok.amriirad.controller.dispatch.DispatchSlipController">
    <top>
        <fx:include fx:id="topBar" source="../shared/top-bar.fxml" />
    </top>

    <center>
        <VBox spacing="16">
            <padding>
                <Insets bottom="24" left="24" right="24" top="24"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label styleClass="text-title" text="إدارة بوردرو الإرسال"/>
                <HBox HBox.hgrow="ALWAYS" />
                <Button styleClass="btn-primary" text="إنشاء بوردرو جديد" onAction="#handleNewSlip">
                    <graphic>
                        <FontIcon iconLiteral="fas-file-alt" iconSize="14" styleClass="icon-light"/>
                    </graphic>
                </Button>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="بحث برقم البوردرو..." prefWidth="250"/>
                <HBox HBox.hgrow="ALWAYS" />
                <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefWidth="24" prefHeight="24"/>
            </HBox>

            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <!-- LEFT: List of existing slips -->
                <TableView fx:id="slipsTable" styleClass="table-view" prefWidth="350">
                    <columns>
                        <TableColumn fx:id="colSlipNumber" text="رقم البوردرو" prefWidth="120" />
                        <TableColumn fx:id="colSlipDate" text="التاريخ" prefWidth="100" />
                        <TableColumn fx:id="colSlipTotal" text="المجموع" prefWidth="100" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- RIGHT: Details -->
                <VBox styleClass="card" spacing="16" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label fx:id="detailTitleLabel" styleClass="text-subheading" text="تفاصيل البوردرو"/>
                        <HBox HBox.hgrow="ALWAYS" />
                        <Button fx:id="printBtn" styleClass="btn-outline" text="طباعة الملحق 5" onAction="#handlePrint" disable="true">
                            <graphic>
                                <FontIcon iconLiteral="fas-print" iconSize="14" styleClass="icon-primary"/>
                            </graphic>
                        </Button>
                    </HBox>

                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="120" halignment="RIGHT"/>
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label styleClass="form-label" text="رقم البوردرو:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="detailNumberField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label styleClass="form-label" text="تاريخ البوردرو:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <DatePicker fx:id="detailDatePicker" disable="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>

                    <Label styleClass="text-subheading" text="الأوامر المرفقة:" style="-fx-padding: 16 0 0 0;"/>
                    
                    <TableView fx:id="ordersTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colOrderNum" text="رقم الأمر" prefWidth="120" />
                            <TableColumn fx:id="colOrderDebtor" text="المدين" prefWidth="150" />
                            <TableColumn fx:id="colOrderAmount" text="المبلغ" prefWidth="100" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <HBox spacing="16" alignment="CENTER_RIGHT">
                        <VBox alignment="CENTER_RIGHT">
                            <Label styleClass="text-small, text-muted" text="المجموع الإجمالي (د.ج):"/>
                            <Label fx:id="totalAmountLabel" styleClass="stat-value" text="0.00"/>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <fx:include fx:id="footer" source="../shared/footer.fxml" />
    </bottom>
</BorderPane>
