<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox prefWidth="700" spacing="20" styleClass="modal-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="org.marrok.amriirad.controller.orders.CancellationFormController">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="modal-header">
        <FontIcon iconLiteral="fas-file-excel" iconSize="24" styleClass="icon-danger"/>
        <VBox>
            <Label fx:id="titleLabel" styleClass="text-subheading" text="إلغاء / تخفيض أمر إيراد"/>
            <Label fx:id="subtitleLabel" styleClass="text-small, text-muted" text="أمر الإيراد: -"/>
        </VBox>
    </HBox>

    <!-- Form Area -->
    <VBox styleClass="card" spacing="20">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20"/>
        </padding>

        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints prefWidth="140" halignment="LEFT"/>
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label styleClass="form-label" text="نوع العملية:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="typeCombo" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label styleClass="form-label" text="رقم العملية:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="cancellationNumField" promptText="يترك فارغاً للتوليد التلقائي" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="250"/>

            <Label styleClass="form-label" text="تاريخ العملية:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <DatePicker fx:id="cancellationDatePicker" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label fx:id="reducedAmountLabel" styleClass="form-label" text="المبلغ المخفض (د.ج):" GridPane.columnIndex="0" GridPane.rowIndex="3" visible="false" managed="false"/>
            <TextField fx:id="reducedAmountField" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="200" visible="false" managed="false"/>

            <Label styleClass="form-label" text="السبب (الأسباب):" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="TOP"/>
            <TextArea fx:id="reasonField" prefRowCount="3" promptText="أدخل سبب الإلغاء أو التخفيض..." GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        </GridPane>
    </VBox>

    <Label fx:id="errorLabel" styleClass="text-small, text-danger" wrapText="true"/>

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button styleClass="btn-outline" text="إلغاء" onAction="#handleCancel"/>
        <Button fx:id="saveBtn" styleClass="btn-danger" text="تأكيد وحفظ" onAction="#handleSave">
            <graphic><FontIcon iconLiteral="fas-check-circle" styleClass="icon-white"/></graphic>
        </Button>
    </HBox>

</VBox>
