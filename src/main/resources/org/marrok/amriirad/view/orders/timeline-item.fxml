<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import java.net.URL?>
<VBox spacing="10.0" style="-fx-padding: 15; -fx-border-radius: 8; -fx-background-color: -fx-control-inner-background;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <FontIcon fx:id="statusIcon" iconSize="20" />
                <Label fx:id="statusLabel" style="-fx-font-size: 14; -fx-font-weight: bold;" />
            </children>
        </HBox>
        <Label fx:id="descriptionLabel" style="-fx-text-fill: -fx-theme-text-muted; -fx-font-size: 12;" wrapText="true" />
        <Label fx:id="timestampLabel" style="-fx-text-fill: -fx-theme-text-muted; -fx-font-size: 11;" />
    </children>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</VBox>
