<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import java.net.URL?>
<BorderPane prefHeight="720" prefWidth="1200" styleClass="main-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.marrok.amriirad.controller.orders.RevenueOrderListController">

    <top>
        <fx:include fx:id="topBar" source="../shared/top-bar.fxml" />
    </top>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <VBox HBox.hgrow="ALWAYS">
                    <Label styleClass="text-heading" text="أوامر الإيراد" />
                    <Label styleClass="text-muted" text="إدارة ومتابعة أوامر الإيراد الصادرة" />
                </VBox>
                
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <TextField fx:id="searchField" prefWidth="250.0" promptText="بحث عن أمر..." styleClass="text-field-search" />
                    <ComboBox fx:id="statusFilterCombo" prefWidth="150.0" promptText="تصفية بالحالة" />
                    <Button onAction="#handleExport" styleClass="btn-secondary" text="تصدير">
                        <graphic><FontIcon iconLiteral="fas-download" iconSize="16" styleClass="icon-primary"/></graphic>
                    </Button>
                    <Button fx:id="addOrderBtn" onAction="#handleNewOrder" styleClass="btn-primary" text="أمر جديد">
                        <graphic><FontIcon iconLiteral="fas-plus" iconSize="16" styleClass="icon-white"/></graphic>
                    </Button>
                    <Button onAction="#handleZeroValues" styleClass="btn-outline" text="القيم المنعدمة">
                        <graphic><FontIcon iconLiteral="fas-file-invoice-dollar" /></graphic>
                    </Button>
                </HBox>
            </HBox>
            </HBox>
            <!-- Table Section -->
            <StackPane VBox.vgrow="ALWAYS">
                <TableView fx:id="tableView" nodeOrientation="RIGHT_TO_LEFT">
                    <columns>
                        <TableColumn fx:id="colOrderNumber" prefWidth="120.0" text="رقم الأمر" />
                        <TableColumn fx:id="colIssueDate" prefWidth="120.0" text="تاريخ الإصدار" />
                        <TableColumn fx:id="colDebtor" prefWidth="200.0" text="المدين" />
                        <TableColumn fx:id="colBudgetChapter" prefWidth="150.0" text="محور الميزانية" />
                        <TableColumn fx:id="colAmount" prefWidth="150.0" text="المبلغ (د.ج)" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="الحالة" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                
                <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="50" maxHeight="50" />
            </StackPane>
        </VBox>
    </center>

    <bottom>
        <fx:include fx:id="footer" source="../shared/footer.fxml" />
    </bottom>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</BorderPane>
