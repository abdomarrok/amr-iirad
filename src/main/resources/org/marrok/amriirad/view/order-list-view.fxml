<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="600" prefWidth="900" styleClass="main-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.marrok.amriirad.controller.RevenueOrderListController">
    <top>
        <VBox spacing="16" style="-fx-padding: 24 24 0 24;">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Button styleClass="btn-outline" onAction="#handleBack">
                    <graphic>
                        <FontIcon iconLiteral="fas-arrow-right" iconSize="14" styleClass="icon-primary"/>
                    </graphic>
                </Button>
                <Label styleClass="text-title" text="قائمة أوامر الإيراد"/>
                <HBox HBox.hgrow="ALWAYS" />
                <Button styleClass="btn-primary" text="أمر إيراد جديد" onAction="#handleNewOrder">
                    <graphic>
                        <FontIcon iconLiteral="fas-plus" iconSize="14" styleClass="icon-light"/>
                    </graphic>
                </Button>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="بحث بالرقم، المدين، الموضوع..." prefWidth="300"/>
                <ComboBox fx:id="statusFilterCombo" promptText="جميع الحالات" prefWidth="150"/>
                <HBox HBox.hgrow="ALWAYS" />
                <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefWidth="24" prefHeight="24"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 16 24 24 24;">
            <TableView fx:id="tableView" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colOrderNumber" text="رقم الأمر" prefWidth="120" />
                    <TableColumn fx:id="colIssueDate" text="تاريخ الإصدار" prefWidth="120" />
                    <TableColumn fx:id="colDebtor" text="المدين" prefWidth="200" />
                    <TableColumn fx:id="colBudgetChapter" text="محور الميزانية" prefWidth="150" />
                    <TableColumn fx:id="colAmount" text="المبلغ (د.ج)" prefWidth="150" />
                    <TableColumn fx:id="colStatus" text="الحالة" prefWidth="120" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </StackPane>
    </center>
</BorderPane>
