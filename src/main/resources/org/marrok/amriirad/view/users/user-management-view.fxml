<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import java.net.URL?>
<BorderPane prefHeight="680" prefWidth="1100" styleClass="main-background" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.marrok.amriirad.controller.users.UserManagementController">

    <top>
        <fx:include fx:id="topBar" source="../shared/top-bar.fxml" />
    </top>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <VBox HBox.hgrow="ALWAYS">
                    <Label styleClass="text-heading" text="إدارة المستخدمين" />
                    <Label styleClass="text-muted" text="إدارة حسابات المستخدمين وصلاحياتهم" />
                </VBox>
                
                <HBox spacing="15.0" alignment="CENTER_RIGHT">
                    <!-- Filter Bar -->
                    <fx:include fx:id="filterBar" source="../shared/components/filter-bar.fxml" />
                    
                    <Separator orientation="VERTICAL" prefHeight="30.0" />
                    
                    <!-- Action Toolbar -->
                    <fx:include fx:id="actionToolbar" source="../shared/components/action-toolbar.fxml" />
                </HBox>
            </HBox>

            <!-- Table Section -->
            <StackPane VBox.vgrow="ALWAYS">
                <TableView fx:id="userTable" nodeOrientation="RIGHT_TO_LEFT">
                <columns>
                    <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                    <TableColumn fx:id="usernameCol" prefWidth="150.0" text="اسم المستخدم" />
                    <TableColumn fx:id="fullNameCol" prefWidth="200.0" text="الاسم الكامل" />
                    <TableColumn fx:id="roleCol" prefWidth="120.0" text="الدور" />
                    <TableColumn fx:id="statusCol" prefWidth="100.0" text="الحالة" />
                </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                
                <fx:include fx:id="emptyState" source="../shared/components/empty-state.fxml" />
                
                <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="50" maxHeight="50" />
            </StackPane>
            
        </VBox>
    </center>

    <bottom>
        <fx:include fx:id="footer" source="../shared/footer.fxml" />
    </bottom>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</BorderPane>
