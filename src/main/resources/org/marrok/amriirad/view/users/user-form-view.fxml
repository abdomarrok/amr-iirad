<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import java.net.URL?>
<VBox fx:id="root" spacing="15.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.marrok.amriirad.controller.users.UserFormController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <Label fx:id="titleLabel" styleClass="header-title" text="إضافة مستخدم جديد" />
    
    <Label styleClass="text-muted" text="الحقول المتسمة بعلامة (*) مطلوبة" />
    
    <GridPane hgap="10.0" vgap="15.0" nodeOrientation="RIGHT_TO_LEFT">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" prefWidth="120.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <HBox spacing="3.0" GridPane.rowIndex="0">
            <Label text="اسم المستخدم:" />
            <Label text="*" styleClass="required-indicator" />
        </HBox>
        <TextField fx:id="usernameField" promptText="مثال: admin_1" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <tooltip><Tooltip text="اسم فريد للدخول إلى النظام (لا يتضمن مسافات)" /></tooltip>
        </TextField>
        
        <Label text="الاسم الكامل:" GridPane.rowIndex="1" />
        <TextField fx:id="fullNameField" promptText="الاسم واللقب" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <tooltip><Tooltip text="الاسم الكامل للمستخدم كما يظهر في التقارير" /></tooltip>
        </TextField>
        
        <HBox spacing="3.0" GridPane.rowIndex="2">
            <Label text="كلمة المرور:" />
            <Label text="*" styleClass="required-indicator" />
        </HBox>
        <PasswordField fx:id="passwordField" promptText="اتركه فارغاً للحفاظ على الكلمة الحالية" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <tooltip><Tooltip text="كلمة مرور قوية (الحروف الكبيرة والصغيرة والأرقام والرموز)" /></tooltip>
        </PasswordField>
        
        <HBox spacing="3.0" GridPane.rowIndex="3">
            <Label text="الدور / الصلاحية:" />
            <Label text="*" styleClass="required-indicator" />
        </HBox>
        <ComboBox fx:id="roleCombo" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <tooltip><Tooltip text="حدد الدور لتعيين الصلاحيات المناسبة" /></tooltip>
        </ComboBox>
        
        <Label text="الحالة:" GridPane.rowIndex="4" />
        <CheckBox fx:id="activeCheck" selected="true" text="حساب نشط" GridPane.columnIndex="1" GridPane.rowIndex="4">
            <tooltip><Tooltip text="الحسابات المجمدة لا تستطيع الدخول للنظام" /></tooltip>
        </CheckBox>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <Label fx:id="errorLabel" styleClass="text-small, text-danger" wrapText="true" />

    <Separator />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="cancelBtn" onAction="#handleCancel" styleClass="btn-secondary" text="إلغاء">
            <tooltip><Tooltip text="إغلاق النموذج بدون حفظ" /></tooltip>
        </Button>
        <Button fx:id="saveBtn" onAction="#handleSave" styleClass="btn-primary" text="حفظ المعلومات">
            <graphic><FontIcon iconLiteral="fas-save"/></graphic>
            <tooltip><Tooltip text="حفظ بيانات المستخدم" /></tooltip>
        </Button>
    </HBox>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</VBox>
