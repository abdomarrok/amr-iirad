<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<?import java.net.URL?>
<VBox spacing="20" styleClass="modal-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.marrok.amriirad.controller.debtors.DebtorFormController">
    <padding>
        <Insets bottom="25" left="25" right="25" top="25" />
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="modal-header">
        <FontIcon iconLiteral="fas-user-edit" iconSize="24" styleClass="icon-primary" />
        <Label fx:id="titleLabel" styleClass="text-subheading" text="إضافة مدين جديد" />
    </HBox>

    <!-- Form Area -->
    <VBox spacing="20" styleClass="card">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints halignment="LEFT" prefWidth="130" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label styleClass="form-label" text="الاسم الكامل:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="fullNameField" promptText="أدخل الاسم الكامل..." GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="form-label" text="نوع المدين:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="typeCombo" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label styleClass="form-label" text="رقم التعريف:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="idNumberField" promptText="NIN / رقم بطاقة التعريف..." GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label styleClass="form-label" text="رقم الهاتف:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="phoneField" maxWidth="250" promptText="0XXXXXXXXX" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label styleClass="form-label" text="العنوان:" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="TOP" />
            <TextArea fx:id="addressField" prefRowCount="3" promptText="أدخل العنوان التفصيلي..." GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label styleClass="form-label" text="الحساب البنكي:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <TextField fx:id="bankAccountField" promptText="رقم الحساب البنكي..." GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <Label styleClass="form-label" text="رقم الضمان (CNAS):" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <TextField fx:id="cnasNumberField" promptText="رقم CNAS..." GridPane.columnIndex="1" GridPane.rowIndex="6" />

            <Label styleClass="form-label" text="الرقم الضريبي (NIF):" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            <TextField fx:id="nifNumberField" promptText="NIF..." GridPane.columnIndex="1" GridPane.rowIndex="7" />

            <Label styleClass="form-label" text="الرقم الإحصائي (NIS):" GridPane.columnIndex="0" GridPane.rowIndex="8" />
            <TextField fx:id="nisNumberField" promptText="NIS..." GridPane.columnIndex="1" GridPane.rowIndex="8" />
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>
    </VBox>

    <Label fx:id="errorLabel" styleClass="text-small, text-danger" wrapText="true" />

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="12">
        <Button onAction="#handleCancel" styleClass="btn-outline" text="إلغاء" />
        <Button fx:id="saveBtn" onAction="#handleSave" styleClass="btn-primary" text="حفظ البيانات">
            <graphic><FontIcon iconLiteral="fas-save" styleClass="icon-white" /></graphic>
        </Button>
    </HBox>
    <stylesheets>
        <URL value="@../../css/master.css" />
    </stylesheets>
</VBox>
